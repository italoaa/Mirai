---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A personal archive for posts, photos, ceramics, and notes.",
} = Astro.props;

const siteTitle = "Mirai";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="masthead">
        <div class="topbar">
          <span>Vol. 1</span>
          <span>Italo Amaya</span>
          <span>{new Date().toLocaleDateString("en")}</span>
        </div>

        <a class="brand" href={base}>Mirai</a>

        <nav class="nav" aria-label="Main navigation">
          <a href={base}>Home</a>
          <a href={`${base}blog/`}>Blog</a>
          <a href={`${base}photos/`}>Photos</a>
          <a href={`${base}ceramics/`}>Ceramics</a>
          <a href={`${base}about/`}>About</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} Mirai.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .masthead {
    padding-top: 1rem;
    border-top: 1px dashed var(--line);
  }

  .topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1rem;
    padding-block: 0.7rem;
    border-bottom: 1px dashed var(--line);
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .topbar span:nth-child(2) {
    text-align: center;
  }

  .topbar span:last-child {
    text-align: right;
  }

.brand {
  display: block;
  width: fit-content;
  margin-inline: auto;
  padding-block: 0.35rem 1.00rem;
  color: var(--ink);
  font-family: var(--font-brand);
  font-size: clamp(4.2rem, 10vw, 7.2rem);
  font-weight: 800;
  line-height: 0.78;
  text-align: center;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: -0.06em;
}

  .nav {
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2rem);
    padding-block: 0.75rem;
    border-top: 1px dashed var(--line);
    border-bottom: 1px dashed var(--line);
    color: #4c4740;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
  }

  .nav a {
    text-decoration: none;
  }

  .nav a:hover {
    color: var(--accent);
  }

  .footer {
    margin-top: 3rem;
    padding-block: 1.25rem;
    border-top: 1px dashed var(--line);
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
  }

  @media (max-width: 640px) {
    .topbar {
      display: none;
    }

    .brand {
      font-size: clamp(3.8rem, 22vw, 5.8rem);
    }

    .nav {
      flex-wrap: wrap;
      gap: 0.85rem;
    }
  }
</style>
