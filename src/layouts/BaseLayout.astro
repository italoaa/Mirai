---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A newspaper-style personal site for posts, photos, ceramics, and notes.",
} = Astro.props;

const siteTitle = "Mirai Dispatch";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="masthead">
        <div class="topbar">
          <span>Personal archive</span>
          <span>Posts, photos, ceramics, about</span>
        </div>

        <a class="brand" href={base}>Mirai Dispatch</a>

        <nav class="nav" aria-label="Main navigation">
          <a href={base}>Home</a>
          <a href={`${base}blog/`}>Blog</a>
          <a href={`${base}photos/`}>Photos</a>
          <a href={`${base}ceramics/`}>Ceramics</a>
          <a href={`${base}about/`}>About</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} Mirai Dispatch.</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .masthead {
    padding: 0.5rem var(--page-padding) 0;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.35rem;
    border-bottom: 1px solid var(--line);
    font-family: Arial, sans-serif;
    font-size: 0.75rem;
  }

  .brand {
    display: block;
    padding-block: 0.7rem 0.45rem;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 10vw, 6.5rem);
    line-height: 0.82;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: -0.055em;
  }

  .nav {
    display: flex;
    justify-content: center;
    gap: clamp(0.75rem, 3vw, 2rem);
    padding-block: 0.45rem;
    border-top: 1px solid var(--line);
    border-bottom: 3px solid var(--line);
    font-family: Arial, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .nav a {
    text-decoration: none;
  }

  .nav a:hover {
    text-decoration: underline;
  }

  .footer {
    margin-top: 3rem;
    padding: 1rem var(--page-padding);
    border-top: 3px solid var(--line);
    font-family: Arial, sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .topbar {
      display: none;
    }

    .nav {
      flex-wrap: wrap;
    }
  }
</style>
