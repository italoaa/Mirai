---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A newspaper-style personal site for posts, photos, ceramics, and notes.",
} = Astro.props;

const siteTitle = "Mirai Dispatch";
const pageTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="masthead">
	<div class="topbar">
	    <span>Vol. 1</span>
	    <span>Personal Archive</span>
	    <span>{new Date().toLocaleDateString("en")}</span>
	</div>

        <a class="brand" href={base}>Mirai News</a>

        <nav class="nav" aria-label="Main navigation">
          <a href={base}>Home</a>
          <a href={`${base}blog/`}>Blog</a>
          <a href={`${base}photos/`}>Photos</a>
          <a href={`${base}ceramics/`}>Ceramics</a>
          <a href={`${base}about/`}>About</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <p>&copy; {new Date().getFullYear()} Mirai Dispatch.</p>
      </footer>
    </div>
  </body>
</html>

<style>
.masthead {
  padding: 0.65rem var(--page-padding) 0;
}

.topbar {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 1rem;
  padding-block: 0.35rem;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  font-family: var(--font-sans);
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.topbar span:first-child {
  text-align: left;
}

.topbar span:last-child {
  text-align: right;
}

.brand {
  display: block;
  padding-block: 0.35rem 0.15rem;
  color: var(--ink);
  font-weight: 900;
  line-height: 0.9;
  text-decoration: none;
  text-transform: none;
  transform: scaleY(0.9);
  transform-origin: left center;
  font-family: var(--font-display);
  font-size: clamp(3.4rem, 13vw, 9rem);
  text-align: center;
  text-shadow:
    0.018em 0 0 var(--ink),
    -0.018em 0 0 var(--ink);
}

.nav {
  display: flex;
  justify-content: center;
  gap: clamp(0.75rem, 3vw, 2.25rem);
  padding-block: 0.5rem;
  border-top: 4px double var(--line);
  border-bottom: 2px solid var(--line);
  font-family: var(--font-sans);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.nav a {
  text-decoration: none;
}

.nav a:hover {
  color: var(--accent);
}

.footer {
  margin-top: 3rem;
  padding: 1rem var(--page-padding);
  border-top: 4px double var(--line);
  font-family: var(--font-sans);
  font-size: 0.8rem;
  color: var(--muted);
}

@media (max-width: 640px) {
  .topbar {
    display: none;
  }

  .brand {
    font-size: clamp(3rem, 18vw, 5rem);
  }

  .nav {
    flex-wrap: wrap;
  }
}
</style>
