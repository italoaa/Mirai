---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RandomGrid from "../../components/RandomGrid.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("ceramics", ({ data }) => !data.draft);

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Ceramics">
  <RandomGrid
    title="Ceramics"
    items={posts}
    emptyMessage="No ceramics posts yet. Add Markdown files under src/content/ceramics."
  />
</BaseLayout>
