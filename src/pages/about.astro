---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <article class="story about-page">
    <p class="kicker">About</p>
    <h1 class="entry-title">A small personal archive (WIP)</h1>
  </article>
</BaseLayout>

<style>
  .about-page {
    margin: 1rem var(--page-padding);
  }

  .article-body {
    max-width: 70ch;
  }

  .article-body :global(p) {
    margin-block: 0 1rem;
  }
</style>
