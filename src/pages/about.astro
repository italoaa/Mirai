---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <article class="story about-page">
    <p class="kicker">About</p>
    <h1 class="entry-title">A small personal archive</h1>
    <p class="dek">
      This site is a place for blog posts, photos with notes, ceramics projects, and a simple
      introduction to who I am.
    </p>

    <div class="article-body">
      <p>
        The structure is intentionally plain for now. It gives you a stable home for content
        without locking you into a visual direction before you are ready.
      </p>
      <p>
        You can expand each section independently as the site grows.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .about-page {
    margin: 1rem var(--page-padding);
  }

  .article-body {
    max-width: 70ch;
  }

  .article-body :global(p) {
    margin-block: 0 1rem;
  }
</style>
