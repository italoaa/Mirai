---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="article-page blog-article">
    <header class="article-hero">
      <p class="kicker">{post.data.featured ? "Featured dispatch" : "Blog post"}</p>

      <h1 class="entry-title">{post.data.title}</h1>

      <p class="dek">{post.data.description}</p>

      <div class="article-meta">
        <span>{post.data.pubDate.toLocaleDateString("en")}</span>
      </div>
    </header>

    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    max-width: none;
  }

  .article-hero {
    max-width: 980px;
    margin-inline: auto;
    padding-block: 2rem 1.5rem;
    text-align: center;
    border-bottom: 1px dashed var(--line);
  }

  .article-hero .entry-title {
    max-width: 12ch;
    margin-inline: auto;
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.82;
    letter-spacing: -0.075em;
  }

  .dek {
    max-width: 42rem;
    margin: 1rem auto 0;
    color: var(--muted);
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    line-height: 1.22;
  }

  .article-meta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .article-meta span + span::before {
    content: "/";
    margin-right: 1rem;
    color: var(--line);
  }

  .article-body {
    max-width: 70ch;
    margin-inline: auto;
    padding-block: 2rem;
    font-size: clamp(1.08rem, 1.4vw, 1.2rem);
  }

  .article-body :global(p:first-child) {
    font-size: 1.25em;
    line-height: 1.35;
  }

  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3) {
    font-family: var(--font-display);
  }

  .article-body :global(h1) {
    font-size: 2.8rem;
  }

  .article-body :global(h2) {
    font-size: 2.2rem;
  }

  .article-body :global(h3) {
    font-size: 1.7rem;
  }

  @media (max-width: 700px) {
    .article-hero {
      text-align: left;
    }

    .article-hero .entry-title,
    .dek {
      margin-inline: 0;
    }

    .article-meta {
      justify-content: flex-start;
      flex-wrap: wrap;
    }
  }
</style>
