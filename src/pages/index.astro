---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const sortNewest = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf();

const [blog, photos, ceramics] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("photos", ({ data }) => !data.draft),
  getCollection("ceramics", ({ data }) => !data.draft),
]);

blog.sort(sortNewest);
photos.sort(sortNewest);
ceramics.sort(sortNewest);

const base = import.meta.env.BASE_URL;

const featuredBlog = blog.filter((post) => post.data.featured);
const lead = featuredBlog[0] ?? blog[0] ?? photos[0] ?? ceramics[0];

const sideItems = [
  ...featuredBlog.filter((post) => post.id !== lead?.id).slice(0, 3),
  photos[0],
  ceramics[0],
].filter(Boolean);

const archiveBlog = blog.filter((post) => post.id !== lead?.id);
---

<BaseLayout title="Mirai Dispatch">
  <section class="front-page">
    <aside class="world-list">
      <h2 class="section-subtitle">Mirai at a Glance</h2>

      {blog.slice(0, 6).map((post, index) => (
        <article class="glance-item">
          <span>{index + 1}</span>
          <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
        </article>
      ))}
    </aside>

    {lead ? (
      <article class="story lead-story">
        <p class="kicker">{lead.data.featured ? "Featured" : lead.collection}</p>

        <h1 class="entry-title">
          <a href={`${base}${lead.collection}/${lead.id}/`}>{lead.data.title}</a>
        </h1>

        <p class="dek">{lead.data.description}</p>
        <p class="meta">{lead.data.pubDate.toLocaleDateString("en")}</p>
      </article>
    ) : null}

    <aside class="side-rail">
      <h2 class="section-subtitle">Latest</h2>

      {sideItems.map((item) => (
        <article>
          <p class="kicker">{item.collection}</p>
          <h3 class="entry-title">
            <a href={`${base}${item.collection}/${item.id}/`}>{item.data.title}</a>
          </h3>
          <p>{item.data.description}</p>
        </article>
      ))}
    </aside>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Blog</h2>

    <div class="entry-list story-grid">
      {archiveBlog.map((post) => (
        <article class="entry">
          <p class="kicker">{post.data.featured ? "Featured" : "Post"}</p>
          <h3 class="entry-title">
            <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
          <p class="meta">{post.data.pubDate.toLocaleDateString("en")}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Photos</h2>

    <div class="entry-list story-grid">
      {photos.map((photo) => (
        <article class="entry image-entry">
          {photo.data.image ? (
            <a href={`${base}photos/${photo.id}/`}>
              <img src={photo.data.image} alt={photo.data.title} />
            </a>
          ) : null}

          <p class="kicker">Photo</p>
          <h3 class="entry-title">
            <a href={`${base}photos/${photo.id}/`}>{photo.data.title}</a>
          </h3>
          <p>{photo.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Ceramics</h2>

    <div class="entry-list story-grid">
      {ceramics.map((piece) => (
        <article class="entry image-entry">
          {piece.data.image ? (
            <a href={`${base}ceramics/${piece.id}/`}>
              <img src={piece.data.image} alt={piece.data.title} />
            </a>
          ) : null}

          <p class="kicker">Ceramics</p>
          <h3 class="entry-title">
            <a href={`${base}ceramics/${piece.id}/`}>{piece.data.title}</a>
          </h3>
          <p>{piece.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .front-page {
    display: grid;
    grid-template-columns: 1fr 1.6fr 1fr;
    gap: 1.5rem;
    padding-block: 1.5rem;
  }

  .world-list,
  .side-rail {
    border-left: 1px dashed var(--line);
    padding-left: 1rem;
  }

  .world-list {
    border-left: 0;
    padding-left: 0;
  }

  .glance-item {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.5rem;
    padding-block: 0.8rem;
    border-bottom: 1px dashed var(--line);
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .glance-item span {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .glance-item a {
    font-weight: 700;
  }

  .lead-story {
    text-align: center;
  }

  .lead-story .entry-title {
    max-width: 12ch;
    margin-inline: auto;
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.9;
  }

  .lead-story .dek {
    max-width: 36rem;
    margin-inline: auto;
    color: #48423a;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.2;
  }

  .side-rail article {
    padding-block: 1rem;
    border-bottom: 1px dashed var(--line);
  }

  .side-rail .entry-title {
    font-size: clamp(1.35rem, 2vw, 1.8rem);
  }

  .story-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .story-grid .entry {
    padding-inline: 1rem;
    border-left: 1px dashed var(--line);
  }

  .story-grid .entry:nth-child(4n + 1) {
    padding-left: 0;
    border-left: 0;
  }

  .image-entry img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    margin-bottom: 0.8rem;
  }

  @media (max-width: 950px) {
    .front-page,
    .story-grid {
      grid-template-columns: 1fr;
    }

    .world-list,
    .side-rail,
    .story-grid .entry {
      padding-left: 0;
      border-left: 0;
    }
  }
</style>
