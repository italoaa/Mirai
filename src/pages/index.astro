---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const sortNewest = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf();

const [blog, photos, ceramics] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("photos", ({ data }) => !data.draft),
  getCollection("ceramics", ({ data }) => !data.draft),
]);

const base = import.meta.env.BASE_URL;

blog.sort(sortNewest);
photos.sort(sortNewest);
ceramics.sort(sortNewest);

const latestStory = blog[0] ?? photos[0] ?? ceramics[0];
const latestPhoto = photos[0];
const latestCeramic = ceramics[0];
const sectionLabel = (value) => value.charAt(0).toUpperCase() + value.slice(1);
---

<BaseLayout title="Mirai Dispatch">
  <section class="front-page">
    {latestStory ? (
      <article class="story lead-story">
        <p class="kicker">{sectionLabel(latestStory.collection)}</p>
        <h1 class="entry-title">
          <a href={`${base}${latestStory.collection}/${latestStory.id}/`}>{latestStory.data.title}</a>
        </h1>
        <p class="dek">{latestStory.data.description}</p>
        <p class="meta">{latestStory.data.pubDate.toLocaleDateString("en")}</p>
      </article>
    ) : (
      <article class="story lead-story">
        <p class="kicker">Start here</p>
        <h1 class="entry-title">A clean place to add your work</h1>
        <p class="dek">
          Add Markdown files under <code>src/content/blog</code>, <code>src/content/photos</code>,
          and <code>src/content/ceramics</code>.
        </p>
      </article>
    )}

    <aside class="story side-rail" aria-label="Latest notes">
      <h2 class="section-title">Latest</h2>

      {latestPhoto ? (
        <article>
          <p class="kicker">Photos</p>
          <h3 class="entry-title">
            <a href={`${base}photos/${latestPhoto.id}/`}>{latestPhoto.data.title}</a>
          </h3>
          <p>{latestPhoto.data.description}</p>
        </article>
      ) : null}

      {latestCeramic ? (
        <article>
          <p class="kicker">Ceramics</p>
          <h3 class="entry-title">
            <a href={`${base}ceramics/${latestCeramic.id}/`}>{latestCeramic.data.title}</a>
          </h3>
          <p>{latestCeramic.data.description}</p>
        </article>
      ) : null}

      {!latestPhoto && !latestCeramic ? <p class="muted">No photos or ceramics entries yet.</p> : null}
    </aside>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Blog</h2>

    <div class="entry-list two-up">
      {blog.length > 0 ? (
        blog.map((post) => (
          <article class="entry">
            <p class="kicker">Post</p>
            <h3 class="entry-title">
              <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <p class="meta">{post.data.pubDate.toLocaleDateString("en")}</p>
          </article>
        ))
      ) : (
        <p class="muted">Add your first blog post under <code>src/content/blog</code>.</p>
      )}
    </div>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Photos</h2>

    <div class="entry-list two-up">
      {photos.length > 0 ? (
        photos.map((photo) => (
          <article class="entry">
            <p class="kicker">Photo note</p>
            <h3 class="entry-title">
              <a href={`${base}photos/${photo.id}/`}>{photo.data.title}</a>
            </h3>
            <p>{photo.data.description}</p>
            <p class="meta">{photo.data.pubDate.toLocaleDateString("en")}</p>
          </article>
        ))
      ) : (
        <p class="muted">Add photo notes under <code>src/content/photos</code>.</p>
      )}
    </div>
  </section>

  <section class="archive-block">
    <h2 class="section-title">Ceramics</h2>

    <div class="entry-list two-up">
      {ceramics.length > 0 ? (
        ceramics.map((piece) => (
          <article class="entry">
            <p class="kicker">Studio log</p>
            <h3 class="entry-title">
              <a href={`${base}ceramics/${piece.id}/`}>{piece.data.title}</a>
            </h3>
            <p>{piece.data.description}</p>
            <p class="meta">{piece.data.pubDate.toLocaleDateString("en")}</p>
          </article>
        ))
      ) : (
        <p class="muted">Add ceramic project notes under <code>src/content/ceramics</code>.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .front-page {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.25rem;
    padding: 1rem var(--page-padding);
    border-bottom: 3px solid var(--line);
  }

  .lead-story {
    min-height: 420px;
    justify-content: end;
    background:
      linear-gradient(rgba(255, 250, 242, 0.08), rgba(255, 250, 242, 0.92)),
      repeating-linear-gradient(
        45deg,
        #ddd4c2,
        #ddd4c2 8px,
        #eee6d9 8px,
        #eee6d9 16px
      );
  }

  .lead-story .entry-title {
    max-width: 14ch;
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.84;
    text-transform: uppercase;
  }

  .lead-story .dek {
    max-width: 58ch;
    font-size: 1.1rem;
  }

  .side-rail {
    border-left: 1px solid var(--line);
    padding-left: 1rem;
  }

  .side-rail article + article {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--soft-line);
  }

  .side-rail .section-title {
    margin-bottom: 1rem;
  }

  .archive-block {
    padding: 1rem var(--page-padding);
  }

  .two-up {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  @media (max-width: 800px) {
    .front-page {
      grid-template-columns: 1fr;
    }

    .side-rail {
      border-left: 0;
      padding-left: 0;
    }

    .two-up {
      grid-template-columns: 1fr;
    }
  }
</style>
