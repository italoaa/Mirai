---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.find((post) => post.data.featured) ?? posts[0];

const secondaryPosts = featured
  ? posts.filter((post) => post.id !== featured.id)
  : [];

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="The Barebones Gazette">
  {
    featured ? (
      <>
        <section class="front-page">
          <article class="lead-story">
            <p class="kicker">{featured.data.category}</p>
            <h1>
              <a href={`${base}blog/${featured.id}/`}>{featured.data.title}</a>
            </h1>
            <p class="dek">{featured.data.description}</p>
            <p class="byline">
              By {featured.data.author} · {featured.data.pubDate.toLocaleDateString("en")}
            </p>
          </article>

          <aside class="side-list" aria-label="Latest posts">
            <h2>Latest</h2>

            {secondaryPosts.map((post) => (
              <article>
                <p class="kicker">{post.data.category}</p>
                <h3>
                  <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </article>
            ))}
          </aside>
        </section>

        <section class="world">
          <h2 class="section-title">World News</h2>

          <div class="card-grid">
            {posts.map((post) => (
              <article class="card">
                <p class="kicker">{post.data.category}</p>
                <h3>
                  <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
                </h3>
                <p>{post.data.description}</p>
              </article>
            ))}
          </div>
        </section>
      </>
    ) : (
      <section class="empty-state">
        <h1 class="section-title">No Posts Yet</h1>
        <p>
          Add Markdown files to <code>src/content/blog/</code> and restart the dev server.
        </p>
      </section>
    )
  }
</BaseLayout>

<style>
  .front-page {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.25rem;
    padding: 1rem var(--page-padding);
    border-bottom: 3px solid var(--line);
  }

  .lead-story {
    min-height: 420px;
    padding: 1rem;
    border: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    justify-content: end;
    background:
      linear-gradient(rgba(255, 253, 247, 0.2), rgba(255, 253, 247, 0.94)),
      repeating-linear-gradient(
        45deg,
        #ddd6c7,
        #ddd6c7 8px,
        #eee8dc 8px,
        #eee8dc 16px
      );
  }

  .lead-story h1 {
    max-width: 13ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 9vw, 7rem);
    line-height: 0.82;
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }

  .lead-story h1 a,
  .card h3 a,
  .side-list h3 a {
    text-decoration: none;
  }

  .lead-story h1 a:hover,
  .card h3 a:hover,
  .side-list h3 a:hover {
    text-decoration: underline;
  }

  .dek {
    max-width: 58ch;
    font-size: 1.1rem;
  }

  .byline {
    margin-bottom: 0;
    font-family: Arial, sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .side-list {
    border-left: 1px solid var(--line);
    padding-left: 1rem;
  }

  .side-list h2 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .side-list article {
    padding-block: 0.85rem;
    border-top: 1px solid var(--soft-line);
  }

  .side-list h3 {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.05;
  }

  .side-list p:last-child {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .world {
    padding: 1rem var(--page-padding);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .card {
    padding-right: 1rem;
    border-right: 1px solid var(--line);
  }

  .card:last-child {
    border-right: 0;
  }

  .card h3 {
    margin: 0;
    font-size: 1.5rem;
    line-height: 1;
  }

  .card p:last-child {
    color: var(--muted);
  }

  .empty-state {
    padding: 3rem var(--page-padding);
    text-align: center;
  }

  .empty-state p {
    color: var(--muted);
  }

  @media (max-width: 800px) {
    .front-page {
      grid-template-columns: 1fr;
    }

    .side-list {
      border-left: 0;
      padding-left: 0;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .card {
      padding-right: 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
