---
import BaseLayout from "../layouts/BaseLayout.astro";
import RandomGrid from "./components/RandomGrid.astro";
import { getCollection } from "astro:content";

const sortNewest = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf();

const [blog, photos, ceramics] = await Promise.all([
  getCollection("blog", ({ data }) => !data.draft),
  getCollection("photos", ({ data }) => !data.draft),
  getCollection("ceramics", ({ data }) => !data.draft),
]);

blog.sort(sortNewest);
photos.sort(sortNewest);
ceramics.sort(sortNewest);

const base = import.meta.env.BASE_URL;

const featuredBlog = blog.filter((post) => post.data.featured);
const lead = featuredBlog[0] ?? blog[0] ?? photos[0] ?? ceramics[0];

const sideItems = [
  ...featuredBlog.filter((post) => post.id !== lead?.id).slice(0, 3),
  photos[0],
  ceramics[0],
].filter(Boolean);

const allDispatches = [...blog, ...photos, ...ceramics]
  .filter((item) => item.id !== lead?.id)
  .sort(sortNewest);

const getHref = (item) => `${base}${item.collection}/${item.id}/`;

const getKicker = (item) => {
  if (item.collection === "blog") {
    return item.data.featured ? "Featured" : "Blog";
  }

  if (item.collection === "photos") {
    return "Photo";
  }

  if (item.collection === "ceramics") {
    return "Ceramics";
  }

  return item.collection;
};

const getExcerpt = (item, length = 200) => {
  const raw = item.body ?? "";

  const clean = raw
    .replace(/```[\s\S]*?```/g, "")
    .replace(/<[^>]+>/g, "")
    .replace(/[#>*_`~-]/g, "")
    .replace(/\s+/g, " ")
    .trim();

  if (!clean) return item.data.description;

  return clean.length > length ? `${clean.slice(0, length)}...` : clean;
};

const leadContent = lead ? getExcerpt(lead, 200) : "";
---

<BaseLayout title="Mirai Dispatch">
  <section class="front-page">
    <aside class="world-list">
      <h2 class="section-subtitle">Mirai at a Glance</h2>

      {blog.slice(0, 6).map((post, index) => (
        <article class="glance-item">
          <span>{index + 1}</span>
          <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
        </article>
      ))}
    </aside>

    {lead ? (
      <article class="story lead-story">
        <p class="kicker">{getKicker(lead)}</p>

        <h1 class="entry-title">
          <a href={getHref(lead)}>{lead.data.title}</a>
        </h1>

        <p class="dek">{lead.data.description}</p>
        <p>{leadContent}</p>
        <p class="meta">{lead.data.pubDate.toLocaleDateString("en")}</p>
      </article>
    ) : null}

    <aside class="side-rail">
      <h2 class="section-subtitle">Latest</h2>

      {sideItems.map((item) => (
        <article>
          <p class="kicker">{getKicker(item)}</p>

          <h3 class="entry-title">
            <a href={getHref(item)}>{item.data.title}</a>
          </h3>

          <p class="dek">{item.data.description}</p>
        </article>
      ))}
    </aside>
  </section>

  <RandomGrid
    title="All Dispatches"
    items={allDispatches}
    emptyMessage="No dispatches yet. Add Markdown files under src/content/blog, src/content/photos, or src/content/ceramics."
  />
</BaseLayout>

<style>
  .front-page {
    display: grid;
    grid-template-columns: 1fr 1.6fr 1fr;
    gap: 1.5rem;
    padding-block: 1.5rem;
  }

  .side-rail {
    border-left: 1px dashed var(--line);
    padding-left: 1rem;
  }

  .dek {
    margin: 1rem 0 0;
    font-size: 0.95rem;
    line-height: 1.2;
    color: var(--muted);
  }

  .world-list {
    padding-right: 1rem;
    border-right: 1px dashed var(--line);
  }

  .section-subtitle {
    margin: 0;
    padding-block: 0 0.75rem;
    border-bottom: 1px dashed var(--line);
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .glance-item {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 0.5rem;
    padding-block: 0.8rem;
    border-bottom: 1px dashed var(--line);
    font-size: 0.95rem;
    line-height: 1.2;
  }

  .glance-item span {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .glance-item a {
    font-weight: 200;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    text-decoration-color: var(--muted);
  }

  .glance-item a:hover {
    color: var(--primary);
    text-decoration-color: var(--primary);
  }

  .lead-story {
    text-align: center;
  }

  .lead-story .entry-title {
    max-width: 12ch;
    margin-inline: auto;
    font-size: clamp(3rem, 5vw, 5.4rem);
    line-height: 0.9;
  }

  .lead-story .dek {
    max-width: 36rem;
    margin-inline: auto;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.2;
  }

  .lead-story > p:not(.kicker):not(.dek):not(.meta) {
    max-width: 48ch;
    margin-inline: auto;
  }

  .side-rail article {
    padding-block: 1rem;
    border-bottom: 1px dashed var(--line);
  }

  .side-rail .entry-title {
    font-size: clamp(1.35rem, 2vw, 1.8rem);
  }

  @media (max-width: 950px) {
    .front-page {
      grid-template-columns: 1fr;
    }

    .world-list,
    .side-rail {
      padding-inline: 0;
      border-inline: 0;
    }

    .side-rail {
      border-top: 1px dashed var(--line);
      padding-top: 1rem;
    }

    .lead-story {
      padding-block: 1rem;
      border-block: 1px dashed var(--line);
    }
  }

  @media (max-width: 640px) {
    .lead-story {
      text-align: left;
    }

    .lead-story .entry-title,
    .lead-story .dek,
    .lead-story > p:not(.kicker):not(.dek):not(.meta) {
      margin-inline: 0;
    }
  }
</style>
