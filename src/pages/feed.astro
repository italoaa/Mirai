---
import BaseLayout from "../layouts/BaseLayout.astro";
import feedData from "../../data/feeds.json";

const articles = feedData.articles;
const formatDate = (date: string) =>
  date
    ? new Date(date).toLocaleDateString("en", {
    day: "numeric",
    month: "short",
    year: "numeric",
      })
    : "Date unavailable";
---

<BaseLayout title="Feed" description="A small reading list of recent posts from feeds I follow.">
  <section class="feed-page">
    <header class="feed-header">
      <p class="kicker">Reading list</p>
      <h1 class="section-title">Feed</h1>
      <p class="feed-intro">
        The five latest posts from a few feeds I follow.
      </p>
    </header>

    {articles.length > 0 ? (
      <div class="feed-list">
        {articles.map((article) => (
          <article class="feed-item">
            <div class="feed-item-meta">
              <span>{article.source}</span>
              <time datetime={article.published}>{formatDate(article.published)}</time>
            </div>
            <h2><a href={article.url} target="_blank" rel="noopener noreferrer">{article.title}</a></h2>
            {article.description && <p>{article.description}</p>}
          </article>
        ))}
      </div>
    ) : (
      <p class="feed-empty">No recent feed items yet. Add your RSS URLs to <code>scripts/update_feeds.py</code>.</p>
    )}
  </section>
</BaseLayout>

<style>
  .feed-page {
    max-width: 860px;
    margin: 1.25rem auto;
    padding-block: 1.25rem;
  }

  .feed-header {
    padding-bottom: 1.25rem;
    border-bottom: 1px dashed var(--line);
  }

  .feed-intro {
    max-width: 48ch;
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .feed-list {
    border-bottom: 1px dashed var(--line);
  }

  .feed-item {
    padding-block: 1.25rem;
    border-bottom: 1px dashed var(--line);
  }

  .feed-item:last-child {
    border-bottom: 0;
  }

  .feed-item-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--primary);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .feed-item-meta time {
    color: var(--muted);
  }

  .feed-item h2 {
    margin: 0.45rem 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 3vw, 2.2rem);
    line-height: 1;
    letter-spacing: -0.045em;
  }

  .feed-item h2 a {
    text-decoration: none;
  }

  .feed-item h2 a:hover {
    color: var(--primary);
  }

  .feed-item p {
    max-width: 68ch;
    margin: 0.55rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .feed-empty {
    padding-block: 1.25rem;
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .feed-item-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
