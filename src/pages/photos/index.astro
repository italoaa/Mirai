---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const photos = await getCollection("photos", ({ data }) => !data.draft);
photos.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Photos">
  <section class="archive-block">
    <h1 class="section-title">Photos</h1>

    <div class="entry-list" style="margin-top: 1rem;">
      {photos.length > 0 ? (
        photos.map((photo) => (
          <article class="entry">
            <p class="kicker">Photo note</p>
            <h2 class="entry-title">
              <a href={`${base}photos/${photo.id}/`}>{photo.data.title}</a>
            </h2>
            <p>{photo.data.description}</p>
            <p class="meta">{photo.data.pubDate.toLocaleDateString("en")}</p>
          </article>
        ))
      ) : (
        <p class="muted">No photo entries yet. Add Markdown files under <code>src/content/photos</code>.</p>
      )}
    </div>
  </section>
</BaseLayout>
