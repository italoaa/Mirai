---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RandomGrid from "../../components/RandomGrid.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("photos", ({ data }) => !data.draft);

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Photos">
  <RandomGrid
    title="Photos"
    items={posts}
    emptyMessage="No photos posts yet. Add Markdown files under src/content/photos."
  />
</BaseLayout>
